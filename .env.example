# Firebase Web SDK public config. Leave blank to use the localStorage fallback.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Client-side fallback affiliate conversion. Use only a public tracking value.
NEXT_PUBLIC_RAKUTEN_AFFILIATE_ID=
NEXT_PUBLIC_RAKUTEN_AFFILIATE_SCID=

# Server-only Rakuten API credentials. Never add NEXT_PUBLIC_ to these keys.
# 2026-02-10の楽天API刷新でaccessKeyが必須に。applicationIdはUUID形式。両方そろわないとモック動作。
RAKUTEN_APPLICATION_ID=
RAKUTEN_ACCESS_KEY=
RAKUTEN_AFFILIATE_ID=

# Server-only Yahoo! Shopping API credentials. Optional VC can be appended as an affiliate parameter.
YAHOO_SHOPPING_APP_ID=
YAHOO_VC=

# Server-only eBay Browse API credentials. EBAY_MARKETPLACE_ID defaults to EBAY_US when blank.
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=
EBAY_MARKETPLACE_ID=

# Optional exchange-rate endpoint for foreign-currency reference JPY conversion. Defaults to Frankfurter.
EXCHANGE_RATE_API_BASE=https://api.frankfurter.dev

# Public deployment settings.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_CONTACT_EMAIL=

# Reserved feature flags. Leave blank unless the corresponding feature is reviewed for release.
ENABLE_ASP_FEED=
ENABLE_CSV_IMPORT=
NEXT_PUBLIC_ENABLE_PUBLIC_SHARE=
